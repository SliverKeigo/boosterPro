generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EducationLevel {
  BACHELOR  @map("本科")
  MASTER    @map("硕士")
  DOCTOR    @map("博士")
  ASSOCIATE @map("大专")
  OTHER     @map("其他")

  @@map("education_level")
}

enum SchoolTier {
  T985_211      @map("985/211")
  GENERAL_FIRST @map("普通一流")
  GENERAL       @map("普通")
  OVERSEAS      @map("海外留学")

  @@map("school_tier")
}

enum GenderType {
  MALE   @map("男")
  FEMALE @map("女")
  ANY    @map("不限")

  @@map("gender_type")
}

enum RecommendationStatus {
  PENDING                   @map("已推荐，待反馈")
  INTERVIEWING              @map("面试中")
  SALARY_NEGO               @map("谈薪中")
  OFFERING                  @map("Offer中")
  ONBOARDING                @map("入职中")
  GUARANTEE                 @map("保证期")
  POST_GUARANTEE_CLOSED     @map("过保关闭")
  RESUME_FAILED             @map("简历失败")
  INTERNAL_RESUME_FAILED    @map("简历(内推)失败")
  INTERVIEW_SCHEDULE_FAILED @map("约面失败")
  INTERVIEW_FAILED          @map("面试失败")
  SALARY_NEGO_FAILED        @map("谈薪失败")
  OFFER_FAILED              @map("offer失败")
  ONBOARD_FAILED            @map("入职失败")
  NOT_PASSED_GUARANTEE      @map("未过保")
  RESIGNED_POST_GUARANTEE   @map("简历挂起（已面）")
  RESIGNED_LOCAL            @map("简历挂起（未面）")

  @@map("recommendation_status")
}

enum OpportunityNature {
  DIRECT   @map("直接客户")
  INDIRECT @map("间接客户")

  @@map("opportunity_nature")
}

model Department {
  id                  Int                        @id @default(autoincrement())
  name                String                     @db.Text
  users               User[]
  groups              Group[]
  hiddenRulesAsSource DepartmentHiddenResource[] @relation("DeptHideSource")
  hiddenRulesAsTarget DepartmentHiddenResource[] @relation("DeptHideTarget")
  createdAt           DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                   @updatedAt @map("updated_at")

  @@map("departments")
}

// 部门-模块「定向可见性」黑名单：一条 (departmentId 源, resource, hiddenFromDeptId 目标)
// = 源部门该模块数据【不给 目标部门 看】。无记录 = 默认对所有部门可见。
// 配置入口：系统管理 → 部门管理 → 部门详情，每个模块列出所有部门、默认全勾，取消某部门即对其隐藏本模块数据。
model DepartmentHiddenResource {
  id               Int        @id @default(autoincrement())
  department       Department @relation("DeptHideSource", fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId     Int        @map("department_id") // 数据所属(源)部门
  resource         String     @db.Text
  hiddenFromDept   Department @relation("DeptHideTarget", fields: [hiddenFromDeptId], references: [id], onDelete: Cascade)
  hiddenFromDeptId Int        @map("hidden_from_dept_id") // 对此(目标)部门隐藏
  createdAt        DateTime   @default(now()) @map("created_at")

  @@unique([departmentId, resource, hiddenFromDeptId])
  @@index([resource, hiddenFromDeptId])
  @@map("department_hidden_resources")
}

// 组：挂在部门之下（部门 → 多个组）。组有组长(leaderId)与成员(User.groupId)。支撑工作计划「仅组长可新增」。
model Group {
  id            Int            @id @default(autoincrement())
  name          String         @db.Text
  department    Department     @relation(fields: [departmentId], references: [id])
  departmentId  Int            @map("department_id")
  leader        User?          @relation("GroupLeader", fields: [leaderId], references: [id])
  leaderId      Int?           @map("leader_id")
  members       User[]         @relation("GroupMembers")
  workPlanItems WorkPlanItem[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([departmentId])
  @@map("groups")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.Text
  description String?  @db.Text
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id                        Int                         @id @default(autoincrement())
  name                      String                      @db.Text
  username                  String                      @unique @db.Text
  email                     String?                     @unique @db.Text
  passwordHash              String?                     @map("password_hash") @db.Text
  department                Department?                 @relation(fields: [departmentId], references: [id])
  departmentId              Int?                        @map("department_id")
  group                     Group?                      @relation("GroupMembers", fields: [groupId], references: [id])
  groupId                   Int?                        @map("group_id")
  ledGroups                 Group[]                     @relation("GroupLeader")
  role                      Role?                       @relation(fields: [roleId], references: [id])
  roleId                    Int?                        @map("role_id")
  submittedCandidates       Candidate[]                 @relation("CandidateSubmitter")
  submittedContacts         CustomerContact[]           @relation("CustomerContactSubmitter")
  salesOpportunities        Opportunity[]               @relation("OpportunitySalesOwner")
  contractSales             Contract[]                  @relation("ContractSalesOwner")
  contractDeliveries        Contract[]                  @relation("ContractDeliveryOwner")
  createdWorkPlans          WorkPlan[]                  @relation("WorkPlanCreatedBy")
  planAssignments           WorkPlanAssignment[]
  urgentRecords             RequirementUrgentRecord[]
  knowledgeRecords          KnowledgeManagementRecord[]
  knowledgeInternalLectures KnowledgeBase[]             @relation("KnowledgeInternalLecturer")
  isAdmin                   Boolean                     @default(false) @map("is_admin")
  tokenVersion              Int                         @default(0) @map("token_version")
  createdCandidates         Candidate[]                 @relation("CandidateCreatedBy")
  createdRequirements       Requirement[]               @relation("RequirementCreatedBy")
  createdSupplements        ClientSupplement[]          @relation("ClientSupplementCreatedBy")
  createdCustomerContacts   CustomerContact[]           @relation("CustomerContactCreatedBy")
  createdTalents            TalentPool[]                @relation("TalentPoolCreatedBy")
  createdOpportunities      Opportunity[]               @relation("OpportunityCreatedBy")
  createdCustomers          Customer[]                  @relation("CustomerCreatedBy")
  createdContracts          Contract[]                  @relation("ContractCreatedBy")
  createdKnowledge          KnowledgeBase[]             @relation("KnowledgeBaseCreatedBy")
  updatedCandidates         Candidate[]                 @relation("CandidateUpdatedBy")
  updatedRequirements       Requirement[]               @relation("RequirementUpdatedBy")
  updatedSupplements        ClientSupplement[]          @relation("ClientSupplementUpdatedBy")
  updatedCustomerContacts   CustomerContact[]           @relation("CustomerContactUpdatedBy")
  updatedTalents            TalentPool[]                @relation("TalentPoolUpdatedBy")
  updatedOpportunities      Opportunity[]               @relation("OpportunityUpdatedBy")
  updatedCustomers          Customer[]                  @relation("CustomerUpdatedBy")
  updatedContracts          Contract[]                  @relation("ContractUpdatedBy")
  updatedKnowledge          KnowledgeBase[]             @relation("KnowledgeBaseUpdatedBy")
  createdAt                 DateTime                    @default(now()) @map("created_at")
  updatedAt                 DateTime                    @updatedAt @map("updated_at")

  @@map("users")
}

model Customer {
  id                 Int                     @id @default(autoincrement())
  fullName           String?                 @map("full_name") @db.Text
  shortName          String                  @map("short_name") @db.Text
  formerName         String?                 @map("former_name") @db.Text
  industry           String?                 @db.Text
  region             String                  @db.Text
  detailedAddress    String                  @map("detailed_address") @db.Text
  companyCulture     String?                 @map("company_culture") @db.Text
  openingSpeech      String?                 @map("opening_speech") @db.Text
  benchmarkCompanies String?                 @map("benchmark_companies") @db.Text
  // 简道云「定位」是移动端定位组件(存位置文字)，非经纬度数字——原 locationLat/Lng 系臆测建模、三库从未有数据，已废弃(库中旧列保留不删)
  location           String?                 @db.Text
  attachmentUrl      String[]                @map("attachment_url")
  officeAddresses    CustomerOfficeAddress[]
  supplements        ClientSupplement[]
  customerContacts   CustomerContact[]
  requirements       Requirement[]
  candidates         Candidate[]
  contracts          Contract[]
  workPlanItems      WorkPlanItem[]
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  createdBy   User? @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("CustomerUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([createdById])
  @@map("customers")
}

model CustomerOfficeAddress {
  id         Int      @id @default(autoincrement())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId Int      @map("customer_id")
  address    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("customer_office_addresses")
}

model ClientSupplement {
  id                    Int                         @id @default(autoincrement())
  customer              Customer                    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId            Int                         @map("customer_id")
  demandCustomer        String?                     @map("demand_customer") @db.Text
  openingSpeech         String?                     @map("opening_speech") @db.Text
  companyCultureWelfare String?                     @map("company_culture_welfare") @db.Text
  notes                 String?                     @db.Text
  attachmentUrl         String[]                    @map("attachment_url")
  demandUpdates         SupplementDemandUpdate[]
  customerProfiles      SupplementCustomerProfile[]
  createdAt             DateTime                    @default(now()) @map("created_at")
  updatedAt             DateTime                    @updatedAt @map("updated_at")

  createdBy   User? @relation("ClientSupplementCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("ClientSupplementUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([createdById])
  @@map("client_supplements")
}

model SupplementDemandUpdate {
  id           Int              @id @default(autoincrement())
  supplement   ClientSupplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)
  supplementId Int              @map("supplement_id")
  date         DateTime?        @db.Date
  content      String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")

  @@map("supplement_demand_updates")
}

model SupplementCustomerProfile {
  id            Int              @id @default(autoincrement())
  supplement    ClientSupplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)
  supplementId  Int              @map("supplement_id")
  specialty     String?          @db.Text
  description   String?          @db.Text
  attachmentUrl String[]         @map("attachment_url")
  createdAt     DateTime         @default(now()) @map("created_at")

  @@map("supplement_customer_profiles")
}

model CustomerContact {
  id                 Int                     @id @default(autoincrement())
  title              String                  @db.Text
  customer           Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId         Int                     @map("customer_id")
  submitter          User?                   @relation("CustomerContactSubmitter", fields: [submitterId], references: [id])
  submitterId        Int?                    @map("submitter_id")
  submitDepartmentId Int?                    @map("submit_department_id")
  contacts           CustomerContactPerson[]
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  createdBy   User? @relation("CustomerContactCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("CustomerContactUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([customerId])
  @@index([createdById])
  @@map("customer_contacts")
}

model CustomerContactPerson {
  id                Int             @id @default(autoincrement())
  customerContact   CustomerContact @relation(fields: [customerContactId], references: [id], onDelete: Cascade)
  customerContactId Int             @map("customer_contact_id")
  contactName       String?         @map("contact_name") @db.Text
  contactTitle      String?         @map("contact_title") @db.Text
  contactPhone      String?         @map("contact_phone") @db.Text
  contactEmail      String?         @map("contact_email") @db.Text
  contactHobby      String?         @map("contact_hobby") @db.Text
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@map("customer_contact_persons")
}

model Requirement {
  id                   Int                          @id @default(autoincrement())
  customer             Customer                     @relation(fields: [customerId], references: [id])
  customerId           Int                          @map("customer_id")
  recruiter            String?                      @db.Text
  positionName         String                       @map("position_name") @db.Text
  headcount            Int
  monthlySalary        String?                      @map("monthly_salary") @db.Text
  annualSalary         String?                      @map("annual_salary") @db.Text
  ageRange             String?                      @map("age_range") @db.Text
  genderRequirement    GenderType?                  @default(ANY) @map("gender_requirement")
  educationRequirement String?                      @map("education_requirement") @db.Text
  languageRequirement  String?                      @map("language_requirement") @db.Text
  status               String[]
  deadline             DateTime?                    @db.Date
  baseCity             String                       @map("base_city") @db.Text
  jobDescription       String?                      @map("job_description") @db.Text
  talentProfile        String?                      @map("talent_profile") @db.Text
  projectExperience    String?                      @map("project_experience") @db.Text
  closeReason          String?                      @map("close_reason") @db.Text
  notes                String?                      @db.Text
  attachmentUrl        String[]                     @map("attachment_url")
  latestUpdate         String?                      @map("latest_update") @db.Text
  industry             String?                      @db.Text
  bonusPoints          String?                      @map("bonus_points") @db.Text
  industryResources    String?                      @map("industry_resources") @db.Text
  followDate           DateTime?                    @map("follow_date") @db.Date
  positionProfiles     RequirementPositionProfile[]
  urgentRecords        RequirementUrgentRecord[]
  candidates           Candidate[]
  workPlanItems        WorkPlanItem[]
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  createdBy   User? @relation("RequirementCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("RequirementUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([customerId])
  @@index([createdById])
  @@map("requirements")
}

model RequirementPositionProfile {
  id                   Int         @id @default(autoincrement())
  requirement          Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  requirementId        Int         @map("requirement_id")
  knowledgeCategory    String?     @map("knowledge_category") @db.Text
  knowledgeAmount      String?     @map("knowledge_amount") @db.Text
  consensusRequirement String?     @map("consensus_requirement") @db.Text
  createdAt            DateTime    @default(now()) @map("created_at")

  @@map("requirement_position_profiles")
}

model RequirementUrgentRecord {
  id            Int         @id @default(autoincrement())
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  requirementId Int         @map("requirement_id")
  member        User?       @relation(fields: [memberId], references: [id])
  memberId      Int?        @map("member_id")
  date          DateTime?   @db.Date
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("requirement_urgent_records")
}

model Candidate {
  id                       Int                               @id @default(autoincrement())
  name                     String                            @db.Text
  birthYear                Int?                              @map("birth_year") // 出生年份（年）
  phone                    String?                           @db.Text
  email                    String?                           @db.Text
  education                EducationLevel?
  schoolTier               String[]                          @map("school_tier") // 院校层次（多选，存枚举 key）
  customer                 Customer?                         @relation(fields: [customerId], references: [id])
  customerId               Int?                              @map("customer_id")
  customerShortName        String?                           @map("customer_short_name") @db.Text
  requirement              Requirement?                      @relation(fields: [requirementId], references: [id])
  requirementId            Int?                              @map("requirement_id")
  recruitmentParty         String?                           @map("recruitment_party") @db.Text
  recruitmentChannel       String                            @map("recruitment_channel") @db.Text
  recommendationTime       DateTime?                         @map("recommendation_time")
  recommendationStatus     RecommendationStatus              @default(PENDING) @map("recommendation_status")
  recommendationReportUrl  String[]                          @map("recommendation_report_url")
  recommendationReason     String?                           @map("recommendation_reason") @db.Text
  interviewProgress        String?                           @map("interview_progress") @db.Text
  failureReason            String?                           @map("failure_reason") @db.Text
  offerDate                DateTime?                         @map("offer_date") @db.Date
  offerOnboardDate         DateTime?                         @map("offer_onboard_date") @db.Date
  offerFileUrl             String[]                          @map("offer_file_url")
  backgroundCheckReportUrl String[]                          @map("background_check_report_url")
  actualOnboardDate        DateTime?                         @map("actual_onboard_date") @db.Date
  salaryPlan               String?                           @map("salary_plan") @db.Text
  guaranteePeriodEnd       DateTime?                         @map("guarantee_period_end") @db.Date
  guaranteePeriodMonths    Int?                              @map("guarantee_period_months")
  tags                     String[]
  notes                    String?                           @db.Text
  submitDepartmentId       Int?                              @map("submit_department_id")
  submitter                User?                             @relation("CandidateSubmitter", fields: [submitterId], references: [id])
  submitterId              Int?                              @map("submitter_id")
  guaranteeCommunications  CandidateGuaranteeCommunication[]
  riskEvents               CandidateRiskEvent[]
  createdAt                DateTime                          @default(now()) @map("created_at")
  updatedAt                DateTime                          @updatedAt @map("updated_at")

  createdBy   User? @relation("CandidateCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("CandidateUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([customerId])
  @@index([requirementId])
  @@index([createdById])
  @@map("candidates")
}

model CandidateGuaranteeCommunication {
  id          Int       @id @default(autoincrement())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId Int       @map("candidate_id")
  date        DateTime? @db.Date
  content     String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("candidate_guarantee_communications")
}

model CandidateRiskEvent {
  id              Int       @id @default(autoincrement())
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId     Int       @map("candidate_id")
  date            DateTime? @db.Date
  riskDescription String?   @map("risk_description") @db.Text // 风险识别
  riskResponse    String?   @map("risk_response") @db.Text // 风险管控与应对
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("candidate_risk_events")
}

model TalentPool {
  id              Int         @id @default(autoincrement())
  name            String      @db.Text
  birthYear       Int?        @map("birth_year") // 出生年份（年）
  gender          GenderType?
  education       String?     @db.Text
  phone           String?     @db.Text
  currentPosition String      @map("current_position") @db.Text
  targetPosition  String?     @map("target_position") @db.Text
  positionType    String?     @map("position_type") @db.Text
  positionLevel   String?     @map("position_level") @db.Text
  age             Int?
  tags            String[]
  resumeUrl       String[]    @map("resume_url")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  createdBy   User? @relation("TalentPoolCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("TalentPoolUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([createdById])
  @@map("talent_pool")
}

model Opportunity {
  id                       Int                   @id @default(autoincrement())
  name                     String                @db.Text
  description              String                @db.Text
  region                   String                @db.Text
  status                   String                @default("线索阶段") @db.Text
  nature                   OpportunityNature     @default(DIRECT)
  contactName              String?               @map("contact_name") @db.Text
  contactTitle             String?               @map("contact_title") @db.Text
  contactInfo              String?               @map("contact_info") @db.Text
  salesDecisionInfo        String                @map("sales_decision_info") @db.Text
  customerDecisionMaker    String                @map("customer_decision_maker") @db.Text
  decisionMakerDescription String                @map("decision_maker_description") @db.Text
  salesOwner               User?                 @relation("OpportunitySalesOwner", fields: [salesOwnerId], references: [id])
  salesOwnerId             Int?                  @map("sales_owner_id")
  attachmentUrl            String[]              @map("attachment_url")
  progressRecords          OpportunityProgress[]
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  createdBy   User? @relation("OpportunityCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("OpportunityUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([createdById])
  @@map("opportunities")
}

model OpportunityProgress {
  id            Int         @id @default(autoincrement())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId Int         @map("opportunity_id")
  date          DateTime?   @db.Date
  description   String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("opportunity_progress")
}

model Contract {
  id                 Int               @id @default(autoincrement())
  customer           Customer          @relation(fields: [customerId], references: [id])
  customerId         Int               @map("customer_id")
  contractName       String            @map("contract_name") @db.Text
  signingYear        Int               @map("signing_year")
  effectiveStart     DateTime          @map("effective_start") @db.Date
  effectiveEnd       DateTime          @map("effective_end") @db.Date
  expiryDate         DateTime          @map("expiry_date") @db.Date
  serviceType        String            @map("service_type") @db.Text
  headhunterFeeRate  Decimal?          @map("headhunter_fee_rate") @db.Decimal(5, 2)
  billingMonths      Int?              @map("billing_months")
  ropFeeRate         Decimal?          @map("rop_fee_rate") @db.Decimal(5, 2)
  salesOwner         User?             @relation("ContractSalesOwner", fields: [salesOwnerId], references: [id])
  salesOwnerId       Int?              @map("sales_owner_id")
  deliveryOwner      User?             @relation("ContractDeliveryOwner", fields: [deliveryOwnerId], references: [id])
  deliveryOwnerId    Int?              @map("delivery_owner_id")
  contractFileUrl    String[]          @map("contract_file_url")
  invoiceInfoText    String?           @map("invoice_info_text") @db.Text
  invoiceInfoFileUrl String[]          @map("invoice_info_file_url")
  notes              String?           @db.Text
  invoices           ContractInvoice[]
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  createdBy   User? @relation("ContractCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("ContractUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([customerId])
  @@index([createdById])
  @@map("contracts")
}

model ContractInvoice {
  id                 Int       @id @default(autoincrement())
  contract           Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId         Int       @map("contract_id")
  invoiceType        String?   @map("invoice_type") @db.Text
  verificationResult String?   @map("verification_result") @db.Text
  amount             String?   @db.Text
  number             String?   @map("invoice_number") @db.Text
  code               String?   @map("invoice_code") @db.Text
  issueDate          DateTime? @map("issue_date") @db.Date
  sourceFileUrl      String[]  @map("source_file_url")
  imageUrl           String[]  @map("image_url")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@map("contract_invoices")
}

model KnowledgeBase {
  id                 Int                         @id @default(autoincrement())
  category           String                      @db.Text
  tags               String[]
  keywords           String                      @db.Text
  fileUrl            String[]                    @map("file_url")
  notes              String?                     @db.Text
  trainingOutline    String?                     @map("training_outline") @db.Text
  internalLecturer   User?                       @relation("KnowledgeInternalLecturer", fields: [internalLecturerId], references: [id])
  internalLecturerId Int?                        @map("internal_lecturer_id")
  externalLecturer   String?                     @map("external_lecturer") @db.Text
  managementRecords  KnowledgeManagementRecord[]
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  createdBy   User? @relation("KnowledgeBaseCreatedBy", fields: [createdById], references: [id])
  createdById Int?  @map("created_by_id")
  updatedBy   User? @relation("KnowledgeBaseUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?  @map("updated_by_id")

  @@index([createdAt])
  @@index([createdById])
  @@map("knowledge_base")
}

model KnowledgeManagementRecord {
  id                 Int           @id @default(autoincrement())
  knowledge          KnowledgeBase @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  knowledgeId        Int           @map("knowledge_id")
  date               DateTime?     @db.Date
  submitter          User?         @relation(fields: [submitterId], references: [id])
  submitterId        Int?          @map("submitter_id")
  details            String?       @db.Text
  reviewParticipants String?       @map("review_participants") @db.Text
  createdAt          DateTime      @default(now()) @map("created_at")

  @@map("knowledge_management_records")
}

// 工作计划 = 某组×某周的「交付需求与计划管理表」。三层：周计划 → 明细行 → 组员分配矩阵。
model WorkPlan {
  id               Int            @id @default(autoincrement())
  weekStart        DateTime       @unique @map("week_start") @db.Date // 周一（一周一条、全公司唯一）
  weekEnd          DateTime       @map("week_end") @db.Date // 周日
  deliveryStrategy String?        @map("delivery_strategy") @db.Text // 本周交付策略
  items            WorkPlanItem[]
  createdBy        User?          @relation("WorkPlanCreatedBy", fields: [createdById], references: [id])
  createdById      Int?           @map("created_by_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@index([createdById])
  @@map("work_plans")
}

// 工作计划明细行：一行 = 一个(客户 × 岗位)的本周交付情况
model WorkPlanItem {
  id               Int                  @id @default(autoincrement())
  workPlan         WorkPlan             @relation(fields: [workPlanId], references: [id], onDelete: Cascade)
  workPlanId       Int                  @map("work_plan_id")
  group            Group                @relation(fields: [groupId], references: [id]) // 明细来源组（按组分页）
  groupId          Int                  @map("group_id")
  customer         Customer?            @relation(fields: [customerId], references: [id])
  customerId       Int?                 @map("customer_id")
  requirement      Requirement?         @relation(fields: [requirementId], references: [id]) // 岗位
  requirementId    Int?                 @map("requirement_id")
  progressNote     String?              @map("progress_note") @db.Text // 交付进展简述
  positionOpenDate DateTime?            @map("position_open_date") @db.Date // 岗位开放时间
  routineHunting   Boolean?             @map("routine_hunting") // 是否例行寻猎
  participation    Int? // 本周参与度
  sortOrder        Int                  @default(0) @map("sort_order")
  assignments      WorkPlanAssignment[]

  @@index([workPlanId])
  @@index([groupId])
  @@map("work_plan_items")
}

// 组员分配矩阵：明细行 × 组员 → 该员工在该岗位的本周计划日期（JSON 日期数组字符串，如 ["2026-06-01","2026-06-03"]；空不入库）
model WorkPlanAssignment {
  id        Int          @id @default(autoincrement())
  item      WorkPlanItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    Int          @map("item_id")
  member    User         @relation(fields: [memberId], references: [id])
  memberId  Int          @map("member_id")
  planDates String?      @map("plan_dates") @db.Text

  @@unique([itemId, memberId])
  @@map("work_plan_assignments")
}

// 权限组：八个业务菜单(resource)各可配置多个权限组，每组持有若干功能权限(actions)与一组成员
model PermissionGroup {
  id         Int                     @id @default(autoincrement())
  name       String                  @db.Text
  resource   String                  @db.Text
  actions    String[]
  applyToAll Boolean                 @default(false) @map("apply_to_all")
  members    PermissionGroupMember[]
  createdAt  DateTime                @default(now()) @map("created_at")
  updatedAt  DateTime                @updatedAt @map("updated_at")

  @@index([resource])
  @@map("permission_groups")
}

// 权限组成员：memberType 区分 USER / DEPARTMENT / ROLE，memberId 指向对应表主键
model PermissionGroupMember {
  id         Int             @id @default(autoincrement())
  group      PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId    Int             @map("group_id")
  memberType String          @map("member_type") @db.Text
  memberId   Int             @map("member_id")
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([groupId])
  @@index([memberType, memberId])
  @@map("permission_group_members")
}

// 数据字典：类型（如 industry 行业 / recruitment_channel 招聘渠道），软枚举下拉选项集中维护
model DictType {
  id        Int        @id @default(autoincrement())
  code      String     @unique @db.Text
  name      String     @db.Text
  remark    String?    @db.Text
  items     DictItem[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("dict_types")
}

// 字典项：归属某字典类型，label 显示值 / value 存储值 / sort 排序 / enabled 启用
model DictItem {
  id        Int      @id @default(autoincrement())
  type      DictType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  typeId    Int      @map("type_id")
  label     String   @db.Text
  value     String   @db.Text
  sort      Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([typeId])
  @@map("dict_items")
}

// AI 提示词：把各 AI 功能的提示词从代码外置到库，管理员可在「提示词管理」改。
// 模板含 {{变量}} 占位，运行时由 getPrompt(key, vars) 填充；库中无该 key 时回退代码内置默认值。
model AiPrompt {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.Text // 业务键，如 job_profile / company_info / supplement_opening
  name        String   @db.Text // 显示名
  content     String   @db.Text // 提示词模板（含 {{占位}}）
  description String?  @db.Text // 说明 / 可用变量
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ai_prompts")
}

// 数据共享授权：把「某人/某部门 录入的 某资源数据」开放给「某用户/某部门」查看或编辑
model DataGrant {
  id            Int      @id @default(autoincrement())
  resource      String   @db.Text // ∈ RESOURCE_KEYS
  sourceType    String   @map("source_type") @db.Text // OWNER | DEPARTMENT
  sourceUserId  Int?     @map("source_user_id")
  sourceDeptId  Int?     @map("source_dept_id")
  granteeType   String   @map("grantee_type") @db.Text // USER | DEPARTMENT
  granteeUserId Int?     @map("grantee_user_id")
  granteeDeptId Int?     @map("grantee_dept_id")
  access        String   @db.Text // VIEW | EDIT（EDIT 蕴含 VIEW）
  grantedById   Int?     @map("granted_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([resource])
  @@index([sourceType, sourceUserId])
  @@index([sourceType, sourceDeptId])
  @@index([granteeType, granteeUserId])
  @@index([granteeType, granteeDeptId])
  @@map("data_grants")
}

// 权限移交审计日志：每次「用户权限移交」记一条。存用户名快照(from/to/operator)——
// 即使用户日后被删，日志仍可读；moved 记各业务表移交条数。仅追加、不改不删。
model TransferLog {
  id           Int      @id @default(autoincrement())
  fromUserId   Int      @map("from_user_id")
  fromUserName String   @map("from_user_name") @db.Text
  toUserId     Int      @map("to_user_id")
  toUserName   String   @map("to_user_name") @db.Text
  operatorId   Int      @map("operator_id")
  operatorName String   @map("operator_name") @db.Text
  moved        Json     @map("moved")
  totalCount   Int      @map("total_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([fromUserId])
  @@index([toUserId])
  @@map("transfer_logs")
}
